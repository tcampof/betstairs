# Ruta del archivo SQLite (local o Render con disco en /app/data)
ARBOL_DB_PATH=./data/arbol.db

# --- Persistencia en producción (elige UNA opción) ---
#
# Opción A — Turso (gratis, recomendado si no usas disco en Render):
#   Crea una BD en https://turso.tech y pega las credenciales.
# TURSO_DATABASE_URL=libsql://tu-db-nombre.turso.io
# TURSO_AUTH_TOKEN=
#
# Opción B — Render Docker con disco persistente (plan Starter ~7€/mes):
#   Monta el disco en /app/data y usa ARBOL_DB_PATH=/app/data/arbol.db
#   Ver render.yaml en el repositorio.

# Secreto para firmar cookies de sesión (mínimo 16 caracteres en producción)
AUTH_SECRET=cambiar-por-un-secreto-largo-y-aleatorio

# Usuario inicial (se crea al ejecutar npm run seed:usuario o al arrancar la app)
BOOTSTRAP_USER_EMAIL=admin@betstairs.local
BOOTSTRAP_USER_PASSWORD=cambiar-esta-contraseña

# The Odds API (opcional, módulo de cuotas)
ODDS_API_KEY=
